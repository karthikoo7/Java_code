package operations;

public class MyNumber implements AdvIntOperations {

	@Override
	public boolean isOdd(int n) {
		// TODO Auto-generated method stub
		if(n % 2 != 0) {
			return true;
		}
		
		return false;
	}

	@Override
	public boolean isEven(int n) {
		// TODO Auto-generated method stub
		if(n % 2 == 0) {
			return true;
		}
		
		return false;
	}

	@Override
	public boolean isPrime(int n) {
		// TODO Auto-generated method stub
		if(n<1) return false;
		while(n>1) {
			for(int i = 2; i*i <= n;i++ ) {
				if(n % i == 0) {
					return false
				}
			}
		}
		
		return true;
	}

	@Override
	public boolean calFactorial(int n) {
		// TODO Auto-generated method stub
		return false;
	}

}
